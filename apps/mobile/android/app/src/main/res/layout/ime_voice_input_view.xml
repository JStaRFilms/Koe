<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="#111827"
  android:orientation="vertical"
  android:padding="16dp">

  <TextView
    android:id="@+id/ime_title"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="@string/app_name"
    android:textColor="#F9FAFB"
    android:textSize="20sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/ime_status"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:text="@string/ime_status_idle"
    android:textColor="#D1D5DB"
    android:textSize="14sp" />

  <TextView
    android:id="@+id/ime_hint"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:text="@string/ime_hint"
    android:textColor="#9CA3AF"
    android:textSize="12sp" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:orientation="horizontal">

    <Button
      android:id="@+id/ime_mic_button"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="@string/ime_action_mic"
      android:textAllCaps="false" />

    <Button
      android:id="@+id/ime_stop_button"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="8dp"
      android:layout_weight="1"
      android:text="@string/ime_action_stop"
      android:textAllCaps="false" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="horizontal">

    <Button
      android:id="@+id/ime_cancel_button"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="@string/ime_action_cancel"
      android:textAllCaps="false" />

    <Button
      android:id="@+id/ime_switch_button"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="8dp"
      android:layout_weight="1"
      android:text="@string/ime_action_switch_keyboard"
      android:textAllCaps="false" />
  </LinearLayout>
</LinearLayout>
